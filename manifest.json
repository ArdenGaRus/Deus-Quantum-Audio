{
  "manifest_version": 3,
  "name": "Quantum Audio 24-Qubit DSP",
  "version": "1.3",
  "description": "Эмуляция квантового 24-кубитного расширения звука через WebGPU",
  "permissions": [
    "tabCapture",
    "activeTab",
    "offscreen",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
